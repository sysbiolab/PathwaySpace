# Subprodutos de Compilação e Checagem do Pacote (CRAN/devtools)
*-Ex.R

# Previews locais de Vinhetas e Cadernos RMarkdown
vignettes/*.html
vignettes/*.pdf
*.utf8.md
*.knit.md
*_cache/
/cache/

# Cache de desenvolvimento local do pkgdown
.pkgdown/

# Conexões e Autenticações (Segurança)
.httr-oauth
rsconnect/
.positai

# R specific
.Rhistory
.Rapp.history
.RData
.Ruserdata
.Rproj.user/
*.Rproj

# R package build artifacts
*.tar.gz
*.zip
src/*.o
src/*.so
src/*.dll

# R check output
/*.Rcheck/
/man/
/doc/

# Security: credentials - secrets
.Renviron
.Renviron.local
.env
.env.*
secrets.R
credentials.R
config/secrets.*
*.pem
*.key
*.p12
*.pfx

# Claude Code
.claude/
.claudeignore

# Data files (avoid committing sensitive data)
data/raw/
data/private/
*.csv
*.xlsx
*.xls
*.rds
*.rda
*.RData

# OS & system files
# Ubuntu/Linux
.DS_Store
*~
.directory
.Trash-*
*.swp
*.swo

# IDE
.vscode/
.positron/
*.code-workspace

# Logs
*.log
npm-debug.log*
